# Copy file này thành ".env" rồi điền giá trị thật của bạn
# KHÔNG commit/chia sẻ file .env thật cho ai, vì chứa token đăng nhập của bạn

# Giá trị header "authorization" nhưng BỎ chữ "Bearer " ở đầu
ACCESS_TOKEN=

# Toàn bộ chuỗi cookie copy nguyên văn từ tab Network (DevTools) của request
COOKIE=

# Danh sách các môn muốn đăng ký, dạng "TenGoiNho:id_to_hoc", cách nhau bằng dấu phẩy
# Ví dụ: COURSES=Chay100m:-5906063664972621884,TiengAnh1:1234567890
# (TenGoiNho là bạn tự đặt để dễ theo dõi log, không ảnh hưởng tới việc đăng ký)
COURSES=

# sv_nganh (thường là 1, để mặc định nếu không chắc)
SV_NGANH=1

# id_rs ban đầu - lấy bằng cách bắt 1 request thử (thành công hoặc thất bại đều được)
# trên trình duyệt trước khi chạy tool, copy field "id_rs" trong payload gửi đi
ID_RS_INIT=

# Khoảng cách giữa các lần thử, tính bằng mili giây
RETRY_INTERVAL_MS=1500

# Số lần thử tối đa trước khi tool tự dừng
MAX_ATTEMPTS=200
